<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/add_transaction"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/primary_text"
        android:layout_marginBottom="20dp"/>

    <RadioGroup
        android:id="@+id/rgType"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@drawable/toggle_background"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/rbInflow"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/inflow_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:checked="true"
            android:button="@null"
            android:textColor="@drawable/toggle_text_color_inflow"
            android:background="@drawable/toggle_item_selected"/>

        <RadioButton
            android:id="@+id/rbOutflow"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/outflow_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:button="@null"
            android:textColor="@drawable/toggle_text_color_outflow"
            android:background="@drawable/toggle_item_unselected"/>
    </RadioGroup>

    <TextView style="@style/InputLabel" android:text="@string/name_text"/>
    <EditText
        android:id="@+id/etName"
        style="@style/InputField"
        android:hint="@string/name_hint"
        android:inputType="text"
        android:importantForAutofill="no"/>

    <TextView style="@style/InputLabel" android:text="@string/amount_text"/>
    <EditText
        android:id="@+id/etAmount"
        style="@style/InputField"
        android:hint="@string/amount_hint"
        android:inputType="numberDecimal"
        android:importantForAutofill="no"/>

    <TextView style="@style/InputLabel" android:text="@string/category_text"/>
    <Spinner
        android:id="@+id/spinnerCategory"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/input_background"
        android:foreground="@null"
        android:textColorHint="@color/hint_text"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"/>

    <EditText
        android:id="@+id/etOtherCategory"
        style="@style/InputField"
        android:hint="@string/other_category_hint"
        android:textColorHint="@color/hint_text"
        android:inputType="text"
        android:visibility="gone"
        android:importantForAutofill="no"/>

    <TextView style="@style/InputLabel" android:text="@string/date_text"/>
    <EditText
        android:id="@+id/etDate"
        style="@style/InputField"
        android:hint="@string/date_hint"
        android:foreground="@null"
        android:background="@drawable/input_background"
        android:inputType="date"
        android:focusable="false"
        android:textColor="@color/primary_text"
        android:textColorHint="@color/hint_text"
        android:clickable="true"
        android:importantForAutofill="no"/>

    <TextView style="@style/InputLabel" android:text="@string/note_text"/>
    <EditText
        android:id="@+id/etNote"
        style="@style/InputField"
        android:hint="@string/note_hint"
        android:inputType="text"
        android:importantForAutofill="no"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/cancel_text"
            android:textAllCaps="false"
            android:layout_marginEnd="8dp"
            android:backgroundTint="@color/cancel_btn_bg"
            android:textColor="@color/cancel_btn_txt"
            style="?android:attr/buttonBarButtonStyle" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/save_text"
            android:textAllCaps="false"
            android:backgroundTint="@color/save_btn_bg"
            android:textColor="@color/save_btn_txt"
            style="?android:attr/buttonBarButtonStyle" />
    </LinearLayout>
</LinearLayout>